{
  "name": "verfix",
  "version": "0.2.8",
  "description": "Browser verification CLI for AI coding agents — run deterministic browser flows, assert UI state, and get structured failure reports. Local-first, Docker-powered.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "npm run test:providers && npm run test:migration && npm run test:noninteractive",
    "test:providers": "ts-node test/providers.test.ts",
    "test:migration": "ts-node test/config-migration.test.ts",
    "test:noninteractive": "ts-node test/noninteractive.test.ts"
  },
  "bin": {
    "verfix": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "browser-testing",
    "verification",
    "ai-agent",
    "playwright",
    "cli",
    "docker",
    "deterministic-testing",
    "ui-testing",
    "assertions",
    "coding-agent",
    "devtools",
    "ci-cd"
  ],
  "author": "Verfix <hello@verfix.dev> (https://verfix.dev)",
  "homepage": "https://verfix.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verfix-dev/verfix.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/verfix-dev/verfix/issues"
  },
  "license": "Apache-2.0",
  "type": "commonjs",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "ajv": "^8.17.1",
    "axios": "^1.16.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.4.0",
    "posthog-node": "^5.38.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.20.0"
  }
}
