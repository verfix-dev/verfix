# ─── Redis Configuration ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Browser Concurrency ───
MAX_CONCURRENCY=3

# ─── Browser Display Mode ───
# Set to 'false' to watch Chromium during local dev (requires a display/X server).
# Leave unset or set to 'true' in Docker/CI — no display server available there.
# PLAYWRIGHT_HEADLESS=false

# ─── AI Configuration (Phase 4) ───
# Uncomment and set your provider of choice.

# OpenAI (default)
# AI_API_KEY=sk-proj-...
# AI_MODEL=gpt-5.4-mini

# Ollama (local)
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3
