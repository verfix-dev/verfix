# ─── Redis Configuration ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Browser Concurrency ────────────────────────────────────────────────────────
MAX_CONCURRENCY=3

# ─── Browser Display Mode ───────────────────────────────────────────────────────
# Set to 'false' to watch Chromium during local dev (requires a display/X server).
# Leave unset or set to 'true' in Docker/CI — no display server available there.
# PLAYWRIGHT_HEADLESS=false

# ─── AI Configuration ───────────────────────────────────────────────────────────
#
# AI_PROVIDER controls which backend is used.
# Supported: openai | anthropic | gemini | openrouter
#
# If AI_PROVIDER is not set, the runtime auto-detects from the API key prefix:
#   sk-ant-*  → anthropic
#   AIza*     → gemini
#   sk-or-*   → openrouter
#   sk-* / default → openai
#
# Run `verfix init` to configure AI interactively from the CLI.

# ── OpenAI (default) ──────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
AI_MODEL=gpt-4o-mini
# Other OpenAI models: gpt-4o, gpt-4.1-mini, o1-mini, o3-mini

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-5
# Other Claude models: claude-3-7-sonnet-20250219, claude-3-5-haiku-20241022, claude-opus-4-5

# ── Google Gemini ─────────────────────────────────────────────────────────────
# AI_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# AI_MODEL=gemini-2.5-flash
# Other Gemini models: gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro

# ── OpenRouter (access to 100+ models) ───────────────────────────────────────
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# AI_MODEL=openai/gpt-4o-mini
# Examples: anthropic/claude-3-5-haiku, google/gemini-2.0-flash, meta-llama/llama-3.1-70b-instruct

# ── Ollama / Local OpenAI-compatible ─────────────────────────────────────────
# AI_PROVIDER=openai
# AI_BASE_URL=http://host.docker.internal:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3.1

# ── Legacy format (still supported) ──────────────────────────────────────────
# Old configs with just AI_API_KEY + AI_MODEL still work:
# AI_API_KEY=sk-proj-...   (auto-detected as OpenAI)
# AI_MODEL=gpt-4o
